

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Device Capability Model",
  "description": "Schema defining the capabilities of a rover device including drive, sensors, safety features, and PTO (Power Take-Off)",
  "type": "object",
  "properties": {
    "device_id": {
      "description": "Unique identifier for the device",
      "type": "string"
    },
    "model": {
      "description": "Device model name",
      "type": "string"
    },
    "firmware_version": {
      "description": "Current firmware version",
      "type": "string",
      "pattern": "^[a-zA-Z0-9.\\-_]+$"
    },
    "capabilities": {
      "description": "Capabilities supported by this device",
      "type": "object",
      "properties": {
        "drive": {
          "$ref": "#/definitions/drive_capability"
        },
        "sensors": {
          "$ref": "#/definitions/sensor_capability"
        },
        "safety": {
          "$ref": "#/definitions/safety_capability"
        },
        "pto": {
          "$ref": "#/definitions/pto_capability",
          "description": "Power Take-Off capabilities (optional)"
        }
      },
      "required": ["drive", "sensors", "safety"]
    },
    "geofences": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/geofence"
      },
      "description": "Geofences configured for this device (if any)"
    }
  },
  "required": ["device_id", "model", "firmware_version", "capabilities"]
}

{
  "definitions": {
    "drive_capability": {
      "type": "object",
      "properties": {
        "max_speed_mps": {
          "description": "Maximum speed in meters per second",
          "type": "number",
          "minimum": 0.1,
          "maximum": 20
        },
        "steering_range_degrees": {
          "description": "Range of steering angles supported (-90 to 90)",
          "type": ["number", "array"],
          "default": [-90, 90]
        },
        "acceleration_mps2": {
          "description": "Maximum acceleration in m/s²",
          "type": "number",
          "minimum": 0.1
        }
      },
      "required": ["max_speed_mps"]
    },

    "sensor_capability": {
      "type": "object",
      "properties": {
        "gps": {
          "description": "GPS sensor capabilities",
          "type": "boolean"
        },
        "imu": {
          "description": "Inertial Measurement Unit (accelerometer, gyroscope)",
          "type": ["boolean", "array"],
          "items": {"enum": ["accel", "gyro", "magnet"]}
        },
        "camera": {
          "description": "Video camera capabilities",
          "type": "object",
          "properties": {
            "resolution": {
              "type": "string",
              "pattern": "^\\d+x\\d+$"
            },
            "fps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60
            }
          }
        },
        "custom_sensors": {
          "description": "Additional custom sensors",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["gps"]
    },

    "safety_capability": {
      "type": "object",
      "properties": {
        "e_stop_supported": {
          "description": "Device supports emergency stop functionality",
          "type": "boolean",
          "default": true
        },
        "dead_man_switch_required": {
          "description": "Requires periodic keepalive signals to maintain control",
          "type": "boolean"
        }
      },
      "required": ["e_stop_supported"]
    },

    "pto_capability": {
      "type": "object",
      "properties": {
        "max_rpm": {
          "description": "Maximum rotations per minute supported",
          "type": "integer",
          "minimum": 100,
          "maximum": 5000
        },
        "pto_count": {
          "description": "Number of PTO outputs available",
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "required": ["max_rpm"]
    },

    "geofence": {
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique identifier for this geofence",
          "type": "string"
        },
        "name": {
          "description": "Human-readable name for the geofence",
          "type": "string"
        },
        "polygon": {
          "description": "Geographic coordinates defining the polygon boundary",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "latitude": {"type": "number"},
              "longitude": {"type": "number"}
            },
            "required": ["latitude", "longitude"]
          },
          "minItems": 3
        },
        "restriction_type": {
          "description": "Type of restriction this geofence enforces",
          "enum": ["no_entry", "speed_limit"],
          "default": "no_entry"
        }
      },
      "required": ["id", "name", "polygon"]
    }
  }
}


